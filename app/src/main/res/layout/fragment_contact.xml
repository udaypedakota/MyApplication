<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GET IN TOUCH"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Me"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Feel free to reach out for collaborations, opportunities, or just a friendly chat!"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="28dp"/>

        <!-- Email Card -->
        <LinearLayout
            android:id="@+id/cardEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="40dp" android:layout_height="40dp"
                android:text="✉️" android:textSize="22sp" android:gravity="center"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Email" android:textColor="@color/text_muted" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="uday.pedakota@gmail.com"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#A855F7" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Location Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="40dp" android:layout_height="40dp"
                android:text="📍" android:textSize="22sp" android:gravity="center"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Location" android:textColor="@color/text_muted" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hyderabad, India"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- LinkedIn Card -->
        <LinearLayout
            android:id="@+id/cardLinkedin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="40dp" android:layout_height="40dp"
                android:text="🔗" android:textSize="22sp" android:gravity="center"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LinkedIn" android:textColor="@color/text_muted" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="linkedin.com/in/uday-pedakota"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#A855F7" android:textSize="22sp"/>
        </LinearLayout>

        <!-- GitHub Card -->
        <LinearLayout
            android:id="@+id/cardGithub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="40dp" android:layout_height="40dp"
                android:text="💻" android:textSize="22sp" android:gravity="center"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="GitHub" android:textColor="@color/text_muted" android:textSize="11sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="github.com/udaypedakota"
                    android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#A855F7" android:textSize="22sp"/>
        </LinearLayout>

        <!-- WhatsApp Button -->
        <Button
            android:id="@+id/btnWhatsapp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💬  Message on WhatsApp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginBottom="24dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>
