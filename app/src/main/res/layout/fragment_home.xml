<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Greeting -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, I'm"
            android:textColor="#A855F7"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp"/>

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uday\nPedakota"
            android:textColor="@color/text_primary"
            android:textSize="42sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginTop="4dp"/>

        <!-- Role -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Stack Developer"
            android:textColor="@color/text_muted"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

        <!-- Bio -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3+ years of experience building scalable Java &amp; Angular applications. Passionate about clean code, microservices, and great user experiences."
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="16dp"/>

        <!-- Hire Me Button -->
        <Button
            android:id="@+id/btnHireMe"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Hire Me"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_primary"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="28dp"
            android:stateListAnimator="@null"/>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3+"
                    android:textColor="#A855F7"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Years Exp."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#A855F7"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10+"
                    android:textColor="#A855F7"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Technologies"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Social Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect with me"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/btnGithub"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="GitHub"
                android:textColor="#A855F7"
                android:textSize="12sp"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnLinkedin"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="LinkedIn"
                android:textColor="#A855F7"
                android:textSize="12sp"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnEmail"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Email"
                android:textColor="#A855F7"
                android:textSize="12sp"
                android:background="@drawable/bg_card"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
